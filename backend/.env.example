# 复制为 .env 后按需修改

# 监听地址与端口（启动命令也可覆盖 port）
HOST=0.0.0.0
PORT=8000

# 前端开发服务器来源（逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 处理接口路径（需与前端一致）
PROCESS_PATH=/api/process

# multipart 上传字段名（前端 form.append 的 key）
UPLOAD_FIELD_NAME=audio

# 单文件大小限制（MB）
MAX_UPLOAD_MB=20

# 音频保存目录，留空则使用仓库根目录下的 Storage 文件夹
STORAGE_DIR=

# 开发时可在浏览器打开 /api/storage/<文件名> 试听；上线建议 false
STORAGE_PUBLIC_READ=true
# 返回 JSON 里 audio_url 的前缀，需与浏览器访问后端一致
BACKEND_PUBLIC_ORIGIN=http://127.0.0.1:8000

# ---------- 百炼 / DashScope（Qwen-ASR，OpenAI 兼容 HTTP）----------
DASHSCOPE_API_KEY=
# 中国内地默认；国际地域见 docs/百炼_接口文档.md
DASHSCOPE_CHAT_COMPLETIONS_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
ASR_MODEL=qwen3-asr-flash
ASR_ENABLE_ITN=false
ASR_TIMEOUT_SECONDS=120
# Data URL 最大长度（字节），与官方 Base64 输入上限对齐
ASR_MAX_PAYLOAD_BYTES=10485760

# ---------- 百炼 CosyVoice TTS（与 ASR 共用 DASHSCOPE_API_KEY）----------
COSYVOICE_TTS_URL=https://dashscope.aliyuncs.com/api/v1/services/audio/tts/SpeechSynthesizer
TTS_MODEL=cosyvoice-v3-flash
TTS_VOICE=longanyang
TTS_FORMAT=mp3
TTS_SAMPLE_RATE=22050
TTS_TIMEOUT_SECONDS=120
TTS_MAX_CHARACTERS=1500

# ---------- DeepSeek（地址抽取 + 话术整合，OpenAI 兼容 HTTP）----------
DEEPSEEK_API_KEY=
DEEPSEEK_CHAT_COMPLETIONS_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_SECONDS=90
DEEPSEEK_TEMPERATURE=0.2
# 整合高德结果时的模型（留空则与 DEEPSEEK_MODEL 相同）
DEEPSEEK_COMPOSE_MODEL=
DEEPSEEK_COMPOSE_TEMPERATURE=0.55

# ---------- 高德 Web 服务（中点相遇 + 逆地理 + 测距，见 docs/高德_MCP与REST_接口文档.md）----------
AMAP_REST_KEY=
AMAP_GEOCODE_URL=https://restapi.amap.com/v3/geocode/geo
AMAP_REGEO_URL=https://restapi.amap.com/v3/geocode/regeo
AMAP_DISTANCE_URL=https://restapi.amap.com/v3/distance
# 0=直线距离 1=驾车导航距离 3=步行规划距离(≤5km)
AMAP_DISTANCE_TYPE=0
AMAP_TIMEOUT_SECONDS=30

# ---------- 日志（相对项目根目录 audio_helper/）----------
LOG_DIR=logs
LOG_FILENAME=audio_helper.log
LOG_LEVEL=INFO
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=5
